@model StatisticsViewModel

@{
    ViewData["title"] = "Multi select - Statistiky / Přehled";
}

<div class="text-center mb-4">
    <h1 class="display-6">Multi select - Statistiky / Přehled</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-bold">
        Celkový přehled za vybrané období
    </div>

    <div class="card-body p-3">
        <div class="table-responsive list-items-table-wrapper app-table-wrapper mb-0">
            <table class="table table-striped table-bordered table-sm mb-0">
                <thead>
                    <tr>
                        <th>Příjmy</th>
                        <th>Výdaje</th>
                        <th>Zůstatek</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.IncomeTotal.ToString("C2")</td>
                        <td>@Model.ExpenseTotal.ToString("C2")</td>
                        <td>
                            <span class="fw-bold @(Model.Balance >= 0 ? "text-success" : "text-danger")">
                                @Model.Balance.ToString("C2")
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>