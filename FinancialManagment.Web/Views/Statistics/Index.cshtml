@model StatisticsViewModel

@{
    ViewData["title"] = "Statistiky / Přehled";
}

<div class="text-center mb-4">
    <h1 class="display-6">Statistiky / Přehled</h1>
</div>

<div class="table-responsive list-items-table-wrapper app-table-wrapper mb-5">
    <table class="table table-striped table-bordered table-sm">
        <thead>
            <tr>
                <th>Příjmy</th>
                <th>Výdaje</th>
                <th>Zůstatek</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>@Model.IncomeTotal.ToString("C2")</td>
                <td>@Model.ExpenseTotal.ToString("C2")</td>
                <td>
                    <span class="fw-semibold @(Model.Balance >= 0 ? "text-success" : "text-danger")">
                        @Model.Balance.ToString("C2")
                    </span>
                </td>
            </tr>
        </tbody>
    </table>
</div>


<form method="get" asp-controller="Statistics" asp-action="Index">

    <div class="card shadow-sm">
        <div class="card-header p-0 text-center fw-bold py-2">
            Filtr statistik
        </div>

        <div class="card-body">
            <div class="row g-3 align-items-end">

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="houseHoldMemberId">Člen</label>
                    <select class="form-select" id="houseHoldMemberId" name="HouseholdMemberId" asp-items="@Model.HouseholdMembers"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="incomeCategoryId">Příjem</label>
                    <select class="form-select" id="incomeCategoryId" name="IncomeCategoryId" asp-items="@Model.IncomeCategories"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="expenseCategoryId">Výdaje</label>
                    <select class="form-select" id="expenseCategoryId" name="ExpenseCategoryId" asp-items="@Model.ExpenseCategories"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="selectedYear">Rok</label>
                    <select class="form-select" id="selectedYear" name="SelectedYear" asp-items="@Model.Years"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="selectedMonth">Měsíc</label>
                    <select class="form-select" id="selectedMonth" name="SelectedMonth" asp-items="@Model.Months"></select>
                </div>

                <div class="col-12 col-md-4">
                    <a class="btn btn-outline-primary">
                        Vymazat filtry @*Dodělat*@
                    </a>
                </div>

            </div>
        </div>

        <div class="card-footer d-flex justify-content-end py-2">
            <button type="submit" class="btn btn-primary">
                Filtrovat
            </button>
        </div>
    </div>

</form>



<div class="m-5">
    <h2 class="fw-bold">Statistiky !!!!</h2>
</div>



<div class="d-flex justify-content-start mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
        Domů
    </a>
</div>
