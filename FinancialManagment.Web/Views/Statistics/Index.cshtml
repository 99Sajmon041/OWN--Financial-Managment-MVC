@model StatisticsViewModel

@{
    ViewData["title"] = "Statistiky / Přehled";
}

<div class="text-center mb-4">
    <h1 class="display-6">Statistiky / Přehled</h1>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header fw-bold">
        Celkový přehled za vybrané období
    </div>

    <div class="card-body p-3">
        <div class="table-responsive list-items-table-wrapper app-table-wrapper mb-0">
            <table class="table table-striped table-bordered table-sm mb-0">
                <thead>
                    <tr>
                        <th>Příjmy</th>
                        <th>Výdaje</th>
                        <th>Zůstatek</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>@Model.IncomeTotal.ToString("C2")</td>
                        <td>@Model.ExpenseTotal.ToString("C2")</td>
                        <td>
                            <span class="fw-bold @(Model.Balance >= 0 ? "text-success" : "text-danger")">
                                @Model.Balance.ToString("C2")
                            </span>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>


<form method="get" asp-controller="Statistics" asp-action="Index">

    <div class="card shadow-sm">
        <div class="card-header p-0 text-center fw-bold py-2">
            Filtr statistik
        </div>

        <div class="card-body">
            <div class="row g-3 align-items-end">

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="houseHoldMemberId">Člen</label>
                    <select class="form-select" id="houseHoldMemberId" name="HouseholdMemberId" asp-items="@Model.HouseholdMembers"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="incomeCategoryId">Příjem</label>
                    <select class="form-select" id="incomeCategoryId" name="IncomeCategoryId" asp-items="@Model.IncomeCategories"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="expenseCategoryId">Výdaje</label>
                    <select class="form-select" id="expenseCategoryId" name="ExpenseCategoryId" asp-items="@Model.ExpenseCategories"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="selectedYear">Rok</label>
                    <select class="form-select" id="selectedYear" name="SelectedYear" asp-items="@Model.Years"></select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold" for="selectedMonth">Měsíc</label>
                    <select class="form-select" id="selectedMonth" name="SelectedMonth" asp-items="@Model.Months"></select>
                </div>

                <div class="col-12 col-md-4">
                    <a class="btn btn-outline-primary"
                       asp-controller="Statistics"
                       asp-action="Index">
                        Vymazat filtry
                    </a>
                </div>

            </div>
        </div>

        <div class="card-footer d-flex justify-content-end py-2">
            <button type="submit" class="btn btn-primary">
                Filtrovat
            </button>
        </div>
    </div>

</form>



<div class="card shadow-sm my-3">
    <div class="card-header fw-bold">
        @(Model.Yearly 
            ? $"Vývoj financí za rok {Model.SelectedYear}" 
            : $"Vývoj financí za {Model.Months.FirstOrDefault(x => x.Value == Model.SelectedMonth.ToString())?.Text} / {Model.SelectedYear}")
    </div>

    <div class="card-body">
        <canvas id="statisticsChart"></canvas>
    </div>
</div>



<div class="d-flex justify-content-start mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
        Domů
    </a>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const incomeChart = JSON.parse('@Html.Raw(JsonSerializer.Serialize(Model.IncomeChart))');
        const expenseChart = JSON.parse('@Html.Raw(JsonSerializer.Serialize(Model.ExpenseChart))');
        const balanceChart = JSON.parse('@Html.Raw(JsonSerializer.Serialize(Model.BalanceChart))');

        const labels = Object.keys(balanceChart);

        const incomeValues = labels.map(label => incomeChart[label] ?? 0);
        const expenseValues = labels.map(label => expenseChart[label] ?? 0);
        const balanceValues = labels.map(label => balanceChart[label] ?? 0);

        const allValues = [...incomeValues, ...expenseValues, ...balanceValues];

        const maxValue = Math.max(...allValues, 0);
        const minValue = Math.min(...allValues, 0);

        const suggestedMax = maxValue > 0 ? maxValue * 1.2 : 100;
        const suggestedMin = minValue < 0 ? minValue * 1.2 : 0;

        const ctx = document.getElementById("statisticsChart");

        new Chart(ctx, {
            type: "line",
            data: {
                labels: labels,
                datasets: [
                    {
                        label: "Zůstatek",
                        data: balanceValues,
                        borderColor: "rgba(108, 117, 125, 0.35)",
                        backgroundColor: "rgba(108, 117, 125, 0.08)",
                        fill: true,
                        tension: 0.35,
                        pointRadius: 1,
                        pointHoverRadius: 3,
                        borderWidth: 1.5
                    },
                    {
                        label: "Příjmy",
                        data: incomeValues,
                        borderColor: "rgba(25, 135, 84, 1)",
                        backgroundColor: "rgba(25, 135, 84, 0)",
                        fill: false,
                        tension: 0,
                        cubicInterpolationMode: 'monotone',
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        borderWidth: 3
                    },
                    {
                        label: "Výdaje",
                        data: expenseValues,
                        borderColor: "rgba(220, 53, 69, 1)",
                        backgroundColor: "rgba(220, 53, 69, 0)",
                        fill: false,
                        tension: 0,
                        cubicInterpolationMode: 'monotone',
                        pointRadius: 3,
                        pointHoverRadius: 5,
                        borderWidth: 3
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                interaction: {
                    mode: "index",
                    intersect: false
                },
                plugins: {
                    legend: {
                        position: "top"
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return `${context.dataset.label}: ${context.raw.toLocaleString('cs-CZ', { style: 'currency', currency: 'CZK' })}`;
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: false,
                        suggestedMin: suggestedMin,
                        suggestedMax: suggestedMax,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString('cs-CZ') + " Kč";
                            }
                        }
                    }
                }
            }
        });
    </script>
}