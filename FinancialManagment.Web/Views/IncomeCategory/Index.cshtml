@model IncomeCategoryIndexViewModel

@{
    ViewData["Title"] = "Kategorie příjmů";
}

<div class="text-center mb-5">
    <h1 class="display-6">Kategorie příjmů</h1>
</div>

<form method="get" class="mb-3" id="FilterForm">
    <input type="hidden" name="Page" value="1" />

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3 align-items-end">

                <div class="col-12 col-md-4 col-lg-4">
                    <label class="form-label">Hledat</label>

                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               id="searchInput"
                               name="Search"
                               value="@Model.Result.Search"
                               placeholder="Název..." />

                        <button type="button"
                                class="btn btn-outline-primary"
                                id="clearSearchBtn"
                                title="Vymazat">
                            ✕
                        </button>
                    </div>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label">Řazení</label>
                    <select name="SortBy" class="form-select" id="sortSelect">
                        <option value="">-- Vyberte --</option>
                        @foreach (var option in Model.SortOptions)
                        {
                            if (option.Value == Model.Result.SortBy)
                            {
                                <option value="@option.Value" selected>@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-md-4 col-lg-3">
                    <label class="form-label">Počet výsledků</label>
                    <select name="PageSize" class="form-select" id="pageSize">
                        @foreach (var option in OptionsBuilder.GetPageSizeOptions())
                        {
                            if (option.Value == Model.Result.PageSize.ToString())
                            {
                                <option value="@option.Value" selected>@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-lg-2">
                    <div class="d-flex flex-wrap gap-3 align-items-center h-100 pt-4">
                        <div class="form-check mb-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="Desc"
                                   value="true"
                                   id="descCheck"
                                   @(Model.Result.Desc ? "checked" : "") />
                            <label class="form-check-label" for="descCheck">
                                Sestupně
                            </label>
                        </div>

                        <div class="form-check mb-0">
                            <input class="form-check-input"
                                   type="checkbox"
                                   name="isActive"
                                   value="true"
                                   id="isActiveCheck"
                                   @(Context.Request.Query["isActive"] == "true" ? "checked" : "") />
                            <label class="form-check-label" for="isActiveCheck">
                                Pouze aktivní
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<div class="d-flex justify-content-end my-2">
    <a asp-controller="IncomeCategory" asp-action="Create" class="btn btn-primary mb-4">
        Přidat kategorii příjmu
    </a>
</div>

<div class="table-responsive list-items-table-wrapper app-table-wrapper">
    <table class="table table-striped list-items-table app-table mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Název</th>
                <th>Aktivní</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Result.Items.Count > 0)
            {
                @foreach (var item in Model.Result.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Name</td>
                        <td>
                            <form method="post" asp-controller="IncomeCategory" asp-action="ChangeStatus" asp-route-id="@item.Id">
                                @Html.AntiForgeryToken()

                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" @(item.IsActive ? "checked" : null) onchange="this.form.submit()" />
                                </div>
                            </form>
                        </td>
                        <td>
                            <a asp-controller="IncomeCategory" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                Upravit
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4">
                        <div class="alert alert-warning mb-0">
                            Zatím žádné nemáte
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

   @if (Model.Result.TotalPages > 1)
    {
        <div class="d-flex justify-content-center">
            <nav>
                <ul class="pagination">

                    <li class="page-item @(Model.Result.HasPrevious ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="IncomeCategory"
                           asp-action="Index"
                           asp-route-Page="@(Model.Result.Page - 1)"
                           asp-route-PageSize="@Model.Result.PageSize"
                           asp-route-Search="@Model.Result.Search"
                           asp-route-SortBy="@Model.Result.SortBy"
                           asp-route-Desc="@Model.Result.Desc">
                            Předchozí
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.Result.TotalPages; i++)
                    {
                        <li class="page-item @(Model.Result.Page == i ? "active" : "")">
                            <a class="page-link"
                               asp-controller="IncomeCategory"
                               asp-action="Index"
                               asp-route-Page="@i"
                               asp-route-PageSize="@Model.Result.PageSize"
                               asp-route-Search="@Model.Result.Search"
                               asp-route-SortBy="@Model.Result.SortBy"
                               asp-route-Desc="@Model.Result.Desc">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.Result.HasNext ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="IncomeCategory"
                           asp-action="Index"
                           asp-route-Page="@(Model.Result.Page + 1)"
                           asp-route-PageSize="@Model.Result.PageSize"
                           asp-route-Search="@Model.Result.Search"
                           asp-route-SortBy="@Model.Result.SortBy"
                           asp-route-Desc="@Model.Result.Desc">
                            Další
                        </a>
                    </li>

                </ul>
            </nav>
        </div>
    }
</div>

<div class="d-flex justify-content-start mt-3">
    <a class="btn btn-outline-primary" asp-controller="Home" asp-action="Index">
        Domů
    </a>
</div>