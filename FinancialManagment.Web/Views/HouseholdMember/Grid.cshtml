@model PagedResultNew<HouseholdMemberViewModel>

@{
    ViewData["Title"] = "Dynamické zobrazení členů domácnosti";
}

<div class="text-center mb-5">
    <h1 class="display-6">Dynamické zobrazení členů domácnosti</h1>
</div>

<form method="get" asp-action="Grid" asp-controller="HouseholdMember" class="mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label">Nickname</label>
            <input type="text"
                   name="Nickname"
                   value="@(Model.GridRequest.Filters.TryGetValue("Nickname", out var nickname) ? nickname : "")"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Is Active</label>
            <select name="IsActive" class="form-select">
                <option value="">-- All --</option>
                <option value="true" selected="@(Model.GridRequest.Filters.TryGetValue("IsActive", out var isActive) && isActive == "true")">Active</option>
                <option value="false" selected="@(Model.GridRequest.Filters.TryGetValue("IsActive", out var isActiveFalse) && isActiveFalse == "false")">Inactive</option>
            </select>
        </div>

        <div class="col-md-2">
            <label class="form-label">Page Size</label>
            <input type="number"
                   name="pageSize"
                   value="@Model.GridRequest.PageSize"
                   min="1"
                   class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Sort Order</label>
            <select name="sortOrder" class="form-select">
                <option value="asc_Nickname" selected="@(Model.GridRequest.SortOrder == "asc_Nickname")">Nickname asc</option>
                <option value="desc_Nickname" selected="@(Model.GridRequest.SortOrder == "desc_Nickname")">Nickname desc</option>
                <option value="asc_Id" selected="@(Model.GridRequest.SortOrder == "asc_Id")">Id asc</option>
                <option value="desc_Id" selected="@(Model.GridRequest.SortOrder == "desc_Id")">Id desc</option>
            </select>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="Grid" asp-controller="HouseholdMember" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<div class="mb-3">
    <strong>Total items:</strong> @Model.Pager.TotalItems <br />
    <strong>Current page:</strong> @Model.Pager.CurrentPage <br />
    <strong>Page size:</strong> @Model.Pager.PageSize <br />
    <strong>Total pages:</strong> @Model.Pager.TotalPages
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nickname</th>
                <th>Is Active</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nickname</td>
                        <td>@item.IsActive</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_Pager", new PagerPartialViewModel
{
    Pager = Model.Pager,
    Action = "Grid",
    Controller = "HouseholdMember",
    SortOrder = Model.GridRequest.SortOrder,
    PageSize = Model.GridRequest.PageSize,
    Filters = Model.GridRequest.Filters
})