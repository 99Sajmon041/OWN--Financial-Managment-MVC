@model PagedResultNew<HouseholdMemberViewModel>

@{
    ViewData["Title"] = "Dynamické zobrazení členů domácnosti";
}

<div class="text-center mb-5">
    <h1 class="display-6">Dynamické zobrazení členů domácnosti</h1>
</div>

@await Component.InvokeAsync("GridFilters", new
{
    modelType = Model.FilterModelType,
    filters = Model.GridRequest.Filters,
    action = ViewContext.RouteData.Values["action"]?.ToString(),
    controller = ViewContext.RouteData.Values["controller"]?.ToString(),
    pageSize = Model.GridRequest.PageSize,
    sortOrder = Model.GridRequest.SortOrder
})

<div class="mb-3">
    <strong>Total items:</strong> @Model.Pager.TotalItems <br />
    <strong>Current page:</strong> @Model.Pager.CurrentPage <br />
    <strong>Page size:</strong> @Model.Pager.PageSize <br />
    <strong>Total pages:</strong> @Model.Pager.TotalPages
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nickname</th>
                <th>Is Active</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nickname</td>
                        <td>@item.IsActive</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_Pager", new PagerPartialViewModel
{
    Pager = Model.Pager,
    Action = "Grid",
    Controller = "HouseholdMember",
    SortOrder = Model.GridRequest.SortOrder,
    PageSize = Model.GridRequest.PageSize,
    Filters = Model.GridRequest.Filters
})