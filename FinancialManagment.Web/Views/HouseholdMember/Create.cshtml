@model HouseholdMemberUpsertViewModel

@{
    ViewData["Title"] = "Přidání nového člena";
}

<div class="text-center mb-5">
    <h1 class="display-6">Přidání nového člena</h1>
</div>

<form method="post" asp-controller="HouseholdMember" asp-action="Create">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3 model-validation"></div>

    <div class="mb-4">
        <label asp-for="Nickname" class="form-label"></label>
        <input asp-for="Nickname" class="form-control"/>
        <span asp-validation-for="Nickname" class="text-danger"></span>
    </div>

    <div class="d-flex justify-content-between flex-wrap gap-2">
        <a asp-controller="HouseholdMember" asp-action="Index" class="btn btn-outline-primary">
            Zpět
        </a>

        <button type="submit" class="btn btn-primary">
            Přidat
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}