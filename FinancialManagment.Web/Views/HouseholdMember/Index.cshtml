@model List<HouseholdMemberViewModel>

@{
    ViewData["Title"] = "Členové domácnosti";
}

<div class="text-center mb-5">
    <h1 class="display-6">Členové domácnosti</h1>
</div>

<div class="d-flex justify-content-end my-2">
    <a asp-controller="HouseholdMember" asp-action="Create" class="btn btn-primary mb-4">
        Přidat člena domácnosti
    </a>
</div>

<div class="table-responsive list-items-table-wrapper app-table-wrapper">
    <table class="table table-striped list-items-table app-table mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Přezdívka</th>
                <th>Stav</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count > 0)
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nickname</td>
                        <td>
                            <form method="post" asp-controller="HouseholdMember" asp-action="ChangeStatus" asp-route-id="@item.Id">
                                @Html.AntiForgeryToken()

                                <div class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" @(item.IsActive ? "checked" : null) onchange="this.form.submit()" />
                                </div>
                            </form>
                        </td>
                        <td>
                            <a asp-controller="HouseholdMember" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                Upravit
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4">
                        <div class="alert alert-warning mb-0">
                            Zatím nemáte žádné členy domácnosti.
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-start mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
        Domů
    </a>
</div>