@model IncomeIndexViewModel

@{
    ViewData["Title"] = "Příjmy";
}

<div class="text-center my-5">
    <h1 class="display-6">Příjmy</h1>
    <div class="fs-2 fw-semibold text-success">
        @Model.IncomeSum.ToString("C2")
    </div>
</div>

<form method="get" class="mb-3" id="FilterForm">
    <input type="hidden" name="page" value="1" />

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-4">

                    <label class="form-label">Hledat</label>
                    <div class="input-group">
                        <input type="text"
                                class="form-control"
                                id="searchInput"
                                name="search"
                                value="@Model.Result.Search"
                                placeholder="Kategorie, člen, popis..."/>

                        <button type="button"
                                class="btn btn-outline-primary"
                                id="clearSearchBtn"
                                title="Vymazat">
                            ✕
                        </button>
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Řazení</label>
                    <select name="sortBy" class="form-select" id="sortSelect">
                        <option value="">--Vyberte--</option>
                        @foreach (var option in Model.SortOptions)
                        {
                            @if (option.Value == Model.Result.SortBy)
                            {
                                <option value="@option.Value" selected>@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Počet výsledků</label>
                    <select name="PageSize" class="form-select" id="pageSize">
                        @foreach (var option in OptionsBuilder.GetPageSizeOptions())
                        {
                            if (option.Value == Model.Result.PageSize.ToString())
                            {
                                <option value="@option.Value" selected>@option.Text</option>
                            }
                            else
                            {
                                <option value="@option.Value">@option.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Typ příjmu</label>
                    <select name="incomeCategoryId" class="form-select" id="incomeCategorySelect">
                        <option value="">-- Všechny --</option>
                        @foreach (var category in Model.IncomeCategoryOptions)
                        {
                            if (Context.Request.Query["incomeCategoryId"] == category.Value)
                            {
                                <option value="@category.Value" selected>@category.Text</option>
                            }
                            else
                            {
                                <option value="@category.Value">@category.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Člen</label>
                    <select name="householdMemberId" class="form-select" id="houseHoldMemberSelect">
                        <option value="">-- Všechny --</option>
                        @foreach (var member in Model.HouseholdMemberOptions)
                        {
                            if (Context.Request.Query["householdMemberId"] == member.Value)
                            {
                                <option value="@member.Value" selected>@member.Text</option>

                            }
                            else
                            {
                                <option value="@member.Value">@member.Text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-12 col-md-4 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="checkbox"
                               name="Desc"
                               value="true"
                               id="descCheck"
                               @(Model.Result.Desc ? "checked" : "") />
                        <label class="form-check-label" for="descCheck">
                            Sestupně
                        </label>
                    </div>
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">Od</label>
                    <input class="form-control"
                           type="date"
                           id="fromInput"
                           name="from"
                           value="@(string.IsNullOrWhiteSpace(Context.Request.Query["from"])
                                          ? DateTime.Now.AddYears(-1).ToString("yyyy-MM-dd")
                                          : Context.Request.Query["from"])" />
                </div>

                <div class="col-12 col-md-3">
                    <label class="form-label">Do</label>
                    <input class="form-control"
                           type="date"
                           id="toInput"
                           name="to"
                           value="@(string.IsNullOrWhiteSpace(Context.Request.Query["to"])
                                          ? DateTime.Now.ToString("yyyy-MM-dd")
                                          : Context.Request.Query["to"])" />
                </div>

            </div>
        </div>
    </div>
</form>

<div class="d-flex justify-content-end my-2">
    <a asp-controller="Income" asp-action="Create" class="btn btn-primary mb-4">
        Přidat příjem
    </a>
</div>

<div class="table-responsive list-items-table-wrapper app-table-wrapper">
    <table class="table table-striped list-items-table app-table mb-0">
        <thead>
            <tr>
                <th>ID</th>
                <th>Člen</th>
                <th>Kategorie</th>
                <th>Částka</th>
                <th>Datum</th>
                <th>Popis</th>
                <th>Akce</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Result.Items.Count > 0)
            {
                @foreach (var item in Model.Result.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.HouseholdMemberNickname</td>
                        <td>@item.IncomeCategoryName</td>
                        <td>@item.Amount.ToString("C2")</td>
                        <td>@item.Date.ToString("dd.MM.yyyy")</td>
                        <td>@(string.IsNullOrWhiteSpace(item.Description) ? "není k dispozici" : item.Description)</td>
                        <td class="d-flex align-items-center gap-2">
                            <a asp-controller="Income" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                Upravit
                            </a>
                            <form method="post" asp-controller="Income" asp-action="Delete" asp-route-id="@item.Id" class="delete-form">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-sm btn-danger" data-confirm-message="Opravdu si přejete smazat tento příjem?">
                                    Smazat
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7">
                        <div class="alert alert-warning mb-0">
                            Zatím žádné nemáte
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.Result.TotalPages > 1)
    {
        <div class="d-flex align-items-center">
            <nav>
                <ul class="pagination">

                    <li class="page-item @(Model.Result.HasPrevious ? "" : "disabled")">
                        <a class="page-link"
                           asp-controller="Income"
                           asp-action="Index"
                           asp-route-Page="@(Model.Result.Page - 1)"
                           asp-route-PageSize="@Model.Result.PageSize"
                           asp-route-Search="@Model.Result.Search"
                           asp-route-SortBy="@Model.Result.SortBy"
                           asp-route-Desc="@Model.Result.Desc"
                           asp-route-householdMemberId="@Context.Request.Query["householdMemberId"]"
                           asp-route-incomeCategoryId="@Context.Request.Query["incomeCategoryId"]"
                           asp-route-from="@Context.Request.Query["from"]"
                           asp-route-to="@Context.Request.Query["to"]">
                            Předchozí
                        </a>
                    </li>

                    @for (int i = 1; i <= Model.Result.TotalPages; i++)
                    {
                        <li class="page-item @(Model.Result.Page == i ? "active" : "")">
                            <a class="page-link"
                               asp-controller="Income"
                               asp-action="Index"
                               asp-route-Page="@i"
                               asp-route-PageSize="@Model.Result.PageSize"
                               asp-route-Search="@Model.Result.Search"
                               asp-route-SortBy="@Model.Result.SortBy"
                               asp-route-Desc="@Model.Result.Desc"
                               asp-route-householdMemberId="@Context.Request.Query["householdMemberId"]"
                               asp-route-incomeCategoryId="@Context.Request.Query["incomeCategoryId"]"
                               asp-route-from="@Context.Request.Query["from"]"
                               asp-route-to="@Context.Request.Query["to"]">
                                @i
                            </a>
                        </li>
                    }

                    <li class="page-item @(Model.Result.HasNext ? "" : "disabled")">
                        <a class="page-link"
                            asp-controller="Income"
                            asp-action="Index"
                            asp-route-Page="@(Model.Result.Page + 1)"
                            asp-route-PageSize="@Model.Result.PageSize"
                            asp-route-Search="@Model.Result.Search"
                            asp-route-SortBy="@Model.Result.SortBy"
                            asp-route-Desc="@Model.Result.Desc"
                           asp-route-householdMemberId="@Context.Request.Query["householdMemberId"]"
                           asp-route-incomeCategoryId="@Context.Request.Query["incomeCategoryId"]"
                           asp-route-from="@Context.Request.Query["from"]"
                           asp-route-to="@Context.Request.Query["to"]">
                             Další
                        </a>
                    </li>

                </ul>
            </nav>
        </div>
    }
</div>

<div class="d-flex justify-content-start mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
        Domů
    </a>
</div>