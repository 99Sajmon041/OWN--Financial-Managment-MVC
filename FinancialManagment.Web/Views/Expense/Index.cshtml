@model PagedResult<ExpenseViewModel>

@{
    ViewData["Title"] = "Výdaje";
}

<div class="text-center my-5">
    <h1 class="display-6">Výdaje</h1>
    <div class="fs-2 fw-semibold text-danger">
        -@ViewBag.TotalAmount.ToString("C2")
    </div>
</div>

@await Component.InvokeAsync("GridFilters", new GridFiltersComponentModel
{
    ModelType = Model.FilterModelType!,
    Filters = Model.GridRequest.Filters,
    Action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty,
    Controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty,
    PageSize = Model.GridRequest.PageSize,
    SortOrder = Model.GridRequest.SortOrder,
    FiltersCollapsed = Model.GridRequest.FiltersCollapsed,
    CustomFilters = Model.CustomFilters
})

<div class="d-flex justify-content-end my-3">
    <a asp-controller="Expense" asp-action="Create" class="btn btn-primary">
        Přidat výdaj
    </a>
</div>

<div class="table-scroll-top">
    <div class="table-scroll-top-inner"></div>
</div>

<div class="table-responsive mb-4 monitoring-table-wrapper">
    <table class="table table-bordered monitoring-table">
        <thead>
            <tr>
                <th>
                    <a asp-action="Index"
                       asp-controller="Expense"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "asc_Id")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-up-short"></i>
                    </a>
                    ID
                    <a asp-action="Index"
                       asp-controller="Expense"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "desc_Id")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-down-short"></i>
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-controller="Income"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "asc_HouseholdMember.Nickname")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-up-short"></i>
                    </a>
                    Člen
                    <a asp-action="Index"
                       asp-controller="Income"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "desc_HouseholdMember.Nickname")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-down-short"></i>
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-controller="Expense"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "asc_Amount")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-up-short"></i>
                    </a>
                    Částka
                    <a asp-action="Index"
                       asp-controller="Expense"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "desc_Amount")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-down-short"></i>
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-controller="Expense"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "asc_Date")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-up-short"></i>
                    </a>
                    Datum
                    <a asp-action="Index"
                       asp-controller="Expense"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "desc_Date")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-down-short"></i>
                    </a>
                </th>
                <th>
                    <a asp-action="Index"
                       asp-controller="Income"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "asc_ExspenseCategory.Name")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-up-short"></i>
                    </a>
                    Kategorie
                    <a asp-action="Index"
                       asp-controller="Income"
                       asp-all-route-data="@GridRequestBuilder.GetRouteValues(Model.GridRequest, "desc_ExspenseCategory.Name")"
                       class="text-decoration-none">
                        <i class="bi bi-arrow-down-short"></i>
                    </a>
                </th>
                <th>
                    Popis
                </th>
                <th>
                    Obrázek
                </th>
                <th>
                    Akce
                </th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Items.Count == 0)
            {
                <tr>
                    <td colspan="8" class="text-center">Záznamy nenalezeny.</td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.HouseholdMemberNickname</td>
                        <td>@item.Amount.ToString("C2")</td>
                        <td>@item.Date.ToString("dd.MM.yyyy")</td>
                        <td>@item.ExpenseCategoryName</td>    
                        <td>@(string.IsNullOrWhiteSpace(item.Description) ? "není k dispozici" : item.Description)</td>
                        <td>
                            @if (!string.IsNullOrWhiteSpace(item.ReceiptFileName))
                            {
                                <img src="~/images/ExpenseReceipts/@item.ReceiptFileName"
                                     asp-append-version="true"
                                     alt="Účtenka"
                                     class="expense-receipt-preview"
                                     style="cursor:pointer"
                                     data-bs-toggle="modal"
                                     data-bs-target="#imageModal-@item.Id" />

                                <div class="modal fade" id="imageModal-@item.Id" tabindex="-1" aria-labelledby="imageModalLabel-@item.Id" aria-hidden="true">
                                    <div class="modal-dialog modal-dialog-centered modal-lg">
                                        <div class="modal-content">
                                            <div class="modal-header">
                                                <h1 class="modal-title fs-5" id="imageModalLabel-@item.Id">Účtenka</h1>
                                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                            </div>
                                            <div class="modal-body text-center">
                                                <img src="~/images/ExpenseReceipts/@item.ReceiptFileName"
                                                     asp-append-version="true"
                                                     alt="Účtenka velké zobrazení"
                                                     class="img-fluid rounded modal-receipt-image" />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <span class="text-muted">Není</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2 flex-wrap">
                                <a asp-controller="Expense" asp-action="Update" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                    Upravit
                                </a>

                                <form method="post" asp-controller="Expense" asp-action="Delete" asp-route-id="@item.Id" class="delete-form m-0">
                                    @Html.AntiForgeryToken()

                                    <button type="submit" class="btn btn-sm btn-danger" data-confirm-message="Opravdu si přejete smazat tento výdaj?">
                                        Smazat
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Component.InvokeAsync("Pager", new PagerPartialViewModel
{
    Pager = Model.Pager,
    Action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty,
    Controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty,
    SortOrder = Model.GridRequest.SortOrder,
    PageSize = Model.GridRequest.PageSize,
    Filters = Model.GridRequest.Filters,
    FiltersCollapsed = Model.GridRequest.FiltersCollapsed
})

<div class="d-flex justify-content-start mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">
        Domů
    </a>
</div>