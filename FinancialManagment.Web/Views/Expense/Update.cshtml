@model ExpenseUpsertViewModel


@{
    ViewData["Title"] = "Úprava výdaje";
}

<div class="text-center mb-5">
    <h1 class="display-6">Úprava výdaje</h1>
</div>

<form asp-controller="Expense" asp-action="Update" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="row justify-content-center">
        <div class="col-11 col-sm-10 col-md-6 col-lg-5">

            <div asp-validation-summary="ModelOnly" class="text-danger text-center mb-3 model-validation"></div>

            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Id" class="form-label"></label>
                <input asp-for="Id" disabled class="form-control" />
                <span asp-validation-for="Id" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="HouseholdMemberId" class="form-label"></label>
                <select asp-for="HouseholdMemberId" class="form-select" asp-items="@Model.HouseholdMembers">
                    <option value="">--Vyberte člena--</option>
                </select>
                <span asp-validation-for="HouseholdMemberId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ExpenseCategoryId" class="form-label"></label>
                <select asp-for="ExpenseCategoryId" class="form-select" asp-items="@Model.ExpenseCategories">
                    <option value="">--Vyberte kategorii--</option>
                </select>
                <span asp-validation-for="ExpenseCategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Amount" class="form-label"></label>
                <input asp-for="Amount" type="number" class="form-control" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" type="date" class="form-control" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.ReceiptFileName))
            {
                <div class="mb-3">
                    <label class="form-label d-block">Aktuální obrázek</label>

                    <div class="d-flex align-items-start gap-3">
                        <div class="border rounded-3 p-2 bg-body-tertiary">
                            <img src="~/images/ExpenseReceipts/@Model.ReceiptFileName"
                                 asp-append-version="true"
                                 alt="Účtenka"
                                 class="expense-receipt-preview" />
                        </div>

                        <button type="submit"
                                formaction="@Url.Action("DeleteImage", "Expense", new { id = Model.Id })"
                                formmethod="post"
                                class="btn btn-danger btn-sm rounded-3 d-flex align-items-center justify-content-center"
                                title="Odstranit obrázek"
                                data-confirm-message="Opravdu si přejete odstranit obrázek natrvalo?"
                                style="width: 38px; height: 38px;">
                            🗑
                        </button>
                    </div>
                </div>
            }

            <div class="mb-4">
                <label asp-for="ReceiptFile" class="form-label"></label>
                <input asp-for="ReceiptFile" type="file" class="form-control" />
                <span asp-validation-for="ReceiptFile" class="text-danger"></span>
            </div>

            <div class="d-flex justify-content-between flex-wrap gap-2">
                <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-primary">
                    Zpět
                </a>

                <button type="submit" class="btn btn-primary">
                    Upravit
                </button>
            </div>
        </div>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}